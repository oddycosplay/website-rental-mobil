        <mxCell id="edge_booking_payment" value="hasOne" style="endArrow=open;endSize=8;html=1;rounded=0;strokeColor=#475569;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontColor=#475569;fontSize=11;fontFamily=Helvetica;" edge="1" source="class_booking" target="class_payment" parent="1">
          <mxGeometry relative="1" as="geometry" />
