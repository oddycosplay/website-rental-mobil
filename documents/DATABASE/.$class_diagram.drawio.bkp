        <!-- 17. CheckoutDraft -> User -->
        <mxCell id="edge_draft_user" value="belongsTo" style="endArrow=open;endSize=8;html=1;rounded=0;strokeColor=#475569;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontColor=#475569;fontSize=11;fontFamily=Helvetica;" edge="1" source="class_draft" target="class_user" parent="1">
