        <!-- 13. Booking -> Review -->
        <mxCell id="edge_booking_review" value="hasOne" style="endArrow=open;endSize=8;html=1;rounded=0;strokeColor=#475569;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontColor=#475569;fontSize=11;fontFamily=Helvetica;" edge="1" source="class_booking" target="class_review" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 14. Booking -> Promo -->
        <mxCell id="edge_booking_promo" value="belongsTo" style="endArrow=open;endSize=8;html=1;rounded=0;strokeColor=#475569;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontColor=#475569;fontSize=11;fontFamily=Helvetica;" edge="1" source="class_booking" target="class_promo" parent="1">
          <mxGeometry relative="1" as="geometry" />
