        <!-- 15. Review -> Customer -->
        <mxCell id="edge_review_customer" value="belongsTo" style="endArrow=open;endSize=8;html=1;rounded=0;strokeColor=#475569;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontColor=#475569;fontSize=11;fontFamily=Helvetica;" edge="1" source="class_review" target="class_customer" parent="1">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

        <!-- 16. Review -> Car -->
        <mxCell id="edge_review_car" value="belongsTo" style="endArrow=open;endSize=8;html=1;rounded=0;strokeColor=#475569;strokeWidth=1.5;edgeStyle=orthogonalEdgeStyle;fontColor=#475569;fontSize=11;fontFamily=Helvetica;" edge="1" source="class_review" target="class_car" parent="1">
          <mxGeometry relative="1" as="geometry" />
